# Frontend
VITE_API_BASE_URL=http://localhost:8080/api

# Backend
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/campus_hub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=campus_hub
SPRING_DATASOURCE_PASSWORD=campus_hub_local_password
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=1
JWT_REMEMBER_ME_REFRESH_TOKEN_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OTP_EXPIRY_MINUTES=10
OTP_EXPOSE_DEV_CODES=true

# Docker Compose
MYSQL_DATABASE=campus_hub
MYSQL_USER=campus_hub
MYSQL_PASSWORD=campus_hub_local_password
MYSQL_ROOT_PASSWORD=campus_hub_root_local_password
REDIS_PORT=6379
